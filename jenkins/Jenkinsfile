pipeline {
    agent any

    environment{
        AWS_ACCOUNT_ID      = "975050024946"
        AWS_REGION          = "us-east-2"
        IMAGE_TAG           = "v${BUILD_NUMBER}"
        ECR_BASE            = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECR_BACKEND         = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/dev-shopnow-backend"
        ECR_FRONTEND        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/dev-shopnow-frontend"
        ECR_ADMIN           = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/dev-shopnow-admin"
        AWS_CREDS_ID        = 'aws-credentials'
        COMPOSE_PROJECT     = 'shopnow'
    }

    stages {
        stage('Install Prerequisites'){
            steps {
                sh '''
                    if command -v aws > /dev/null 2>&1; then
                        echo "aws-cli already installed: $(aws --version)"
                    else
                        echo "Installing aws-cli and dependencies..."
                        if command -v apk > /dev/null 2>&1; then
                            apk add --no-cache aws-cli git curl
                        elif command -v apt-get > /dev/null 2>&1; then
                            apt-get update -y && apt-get install -y awscli git curl
                        elif command -v yum > /dev/null 2>&1; then
                            yum install -y awscli git curl
                        else
                            echo "ERROR: No supported package manager found"
                            exit 1
                        fi
                    fi
                    echo "--- Tool versions ---"
                    aws --version
                    git --version
                    docker --version
                '''
            }
        }

        stage('Verify AWS Access and Login to ECR') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: "${AWS_CREDS_ID}",
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh '''
                        echo "Verifying AWS credentials..."
                        aws sts get-caller-identity

                        echo "Listing ECR repositories..."
                        aws ecr describe-repositories --region $AWS_REGION || true

                        echo "Logging in to ECR..."
                        aws ecr get-login-password --region $AWS_REGION \
                            | docker login --username AWS --password-stdin $ECR_BASE

                        echo "ECR login successful."
                    '''
                }
            }
        }

        stage('Building Images for all services'){
            steps{
                script {
                    // Build only the services that have a Dockerfile (skip mongo)
                    sh """
                        echo "Building all images using Docker compose file"
                        docker compose -p ${COMPOSE_PROJECT} -f docker-compose.yml build frontend admin backend
                        echo "--- Images Created for admin,backend and frontend ---"
                        docker images | grep ${COMPOSE_PROJECT} || true
                    """
                    
                    // Tagging images based on services to respective ECR Repo (skip mongo)
                    sh """
                        if docker image inspect ${COMPOSE_PROJECT}-frontend > /dev/null 2>&1; then
                            LOCAL_IMAGE="${COMPOSE_PROJECT}-frontend"
                            echo "Tagging \$LOCAL_IMAGE -> ${ECR_FRONTEND}:frontend-${IMAGE_TAG}"
                            docker tag \$LOCAL_IMAGE ${ECR_FRONTEND}:frontend-${IMAGE_TAG}
                        fi
                        if docker image inspect ${COMPOSE_PROJECT}-backend > /dev/null 2>&1; then
                            LOCAL_IMAGE="${COMPOSE_PROJECT}-backend"
                            echo "Tagging \$LOCAL_IMAGE -> ${ECR_BACKEND}:backend-${IMAGE_TAG}"
                            docker tag \$LOCAL_IMAGE ${ECR_BACKEND}:backend-${IMAGE_TAG}
                        fi
                        if docker image inspect ${COMPOSE_PROJECT}-admin > /dev/null 2>&1; then
                            LOCAL_IMAGE="${COMPOSE_PROJECT}-admin"
                            echo "Tagging \$LOCAL_IMAGE -> ${ECR_ADMIN}:admin-${IMAGE_TAG}"
                            docker tag \$LOCAL_IMAGE ${ECR_ADMIN}:admin-${IMAGE_TAG} 
                        fi                       
                    """
                }       
            }
        }

        stage('Pushing all tagged images into ECR Repos'){
            steps{
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: "${AWS_CREDS_ID}",
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    script{
                        sh """
                            echo "Pushing ${ECR_FRONTEND}:frontend-${IMAGE_TAG} ..."
                            docker push ${ECR_FRONTEND}:frontend-${IMAGE_TAG}
                            echo "Successfully pushed frontend"

                            echo "Pushing ${ECR_BACKEND}:backend-${IMAGE_TAG} ..."
                            docker push ${ECR_BACKEND}:backend-${IMAGE_TAG}
                            echo "Successfully pushed backend"

                            echo "Pushing ${ECR_ADMIN}:admin-${IMAGE_TAG} ..."
                            docker push ${ECR_ADMIN}:admin-${IMAGE_TAG}
                            echo "Successfully pushed admin"

                        """
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Cleaning up local Docker images..."
                    sh """
                        docker rmi ${ECR_FRONTEND}:frontend-${IMAGE_TAG} || true
                        docker rmi ${ECR_BACKEND}:backend-${IMAGE_TAG}   || true
                        docker rmi ${ECR_ADMIN}:admin-${IMAGE_TAG}        || true
                        docker system prune -f
                    """
            }
        }
        success {
            echo "All microservices built and pushed to ECR successfully!"
            emailext(
                to: 'devendra8182@gmail.com',
                subject: "SUCCESS: ShopNow CI/CD Pipeline - Build #${env.BUILD_NUMBER}",
                body: """
                    Build #${env.BUILD_NUMBER} completed successfully.

                    Image Tag : ${env.IMAGE_TAG}

                    Backend ECR  : ${env.ECR_BACKEND}
                    Tags pushed  : backend-${env.IMAGE_TAG}

                    Frontend ECR : ${env.ECR_FRONTEND}
                    Tag pushed   : frontend-${env.IMAGE_TAG}

                    Admin ECR : ${env.ECR_ADMIN}
                    Tag pushed   : admin-${env.IMAGE_TAG}

                    View build: ${env.BUILD_URL}
                """
            )
        }

        failure {
            echo "Pipeline failed. Images were NOT pushed to ECR."
            emailext(
                to: 'devendra8182@gmail.com',
                subject: "FAILURE: ShopNow CI/CD Pipeline - Build #${env.BUILD_NUMBER}",
                body: """
                    Build #${env.BUILD_NUMBER} FAILED.

                    Please check the Jenkins console output for details:
                    ${env.BUILD_URL}console
                """
            )
        }
    }
}